<?xml version="1.0"?>
<transfers xmlns="spryker:transfer-01" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="spryker:transfer-01 http://static.spryker.com/transfer-01.xsd">

    <transfer name="WebhookMessage">
        <property name="type" type="string"/>
        <property name="payload" type="array" singular="payload"/>
        <property name="metadata" type="array" singular="metadata"/>
    </transfer>

    <transfer name="WebhookProcessorResponse">
        <property name="success" type="bool"/>
        <property name="message" type="string"/>
        <property name="processedBy" type="string"/>
        <property name="errors" type="WebhookProcessorError[]" singular="error"/>
    </transfer>

    <transfer name="WebhookProcessorError">
        <property name="code" type="string"/>
        <property name="message" type="string"/>
    </transfer>

    <transfer name="RestWebhookProcessorRequestAttributes">
        <property name="type" type="string"/>
        <property name="payload" type="array" singular="payload"/>
        <property name="metadata" type="array" singular="metadata"/>
        <!-- CloudEvents format support -->
        <property name="data" type="array" singular="data"/>
        <property name="id" type="string"/>
        <property name="source" type="string"/>
        <property name="specversion" type="string"/>
        <property name="subject" type="string"/>
        <property name="time" type="string"/>
        <property name="datacontenttype" type="string"/>
        <property name="dataschema" type="string"/>
    </transfer>

    <transfer name="RestWebhookProcessorResponseAttributes">
        <property name="success" type="bool"/>
        <property name="message" type="string"/>
        <property name="processedBy" type="string"/>
    </transfer>

    <transfer name="QueueSendMessage">
        <property name="body" type="string"/>
        <property name="queueName" type="string"/>
        <property name="queuePoolName" type="string"/>
    </transfer>

    <transfer name="WebhookProcessorGatewayRequest">
        <property name="webhookMessage" type="WebhookMessage"/>
    </transfer>

    <transfer name="WebhookProcessorGatewayResponse">
        <property name="webhookProcessorResponse" type="WebhookProcessorResponse"/>
        <property name="isSuccess" type="bool"/>
    </transfer>

</transfers>
